    "test:playwright": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.0",
    "jest": "^30.2.0",
    "openapi-typescript": "^7.10.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}

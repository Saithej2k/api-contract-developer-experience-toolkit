{
  "name": "@api-contract-toolkit/client",
  "version": "1.0.0",
  "private": true,
  "description": "OpenAPI-generated TypeScript client helpers for the API Contract Toolkit.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "openapi-typescript ../docs/openapi.json -o src/generated/schema.ts",
